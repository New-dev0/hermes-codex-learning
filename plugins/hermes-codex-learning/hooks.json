{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/session_start.py",
            "timeout": 10,
            "statusMessage": "Connecting Codex session to Hermes learning inbox"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/user_prompt_submit.py",
            "timeout": 10,
            "statusMessage": "Scanning prompt for Hermes learning signals"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/pre_tool_use_policy.py",
            "timeout": 10,
            "statusMessage": "Checking Hermes/Codex learning safety policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/post_tool_use_review.py",
            "timeout": 10,
            "statusMessage": "Capturing tool result for Hermes learning"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/stop_export_summary.py",
            "timeout": 30,
            "statusMessage": "Exporting Codex session summary for Hermes"
          }
        ]
      }
    ]
  }
}
